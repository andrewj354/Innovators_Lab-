# API Gateway Configuration
API_GATEWAY_DEBUG=True
API_GATEWAY_SECRET_KEY=your-secret-key-change-in-production
API_GATEWAY_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
API_GATEWAY_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/innovators_db
API_GATEWAY_REDIS_URL=redis://redis:6379/0

# User Service Configuration
USER_SERVICE_DEBUG=True
USER_SERVICE_SECRET_KEY=user-service-secret-key-change-in-production
USER_SERVICE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/user_db
USER_SERVICE_REDIS_URL=redis://redis:6379/1
USER_SERVICE_JWT_SECRET=your-jwt-secret-key

# Tournament Service Configuration
TOURNAMENT_SERVICE_DEBUG=True
TOURNAMENT_SERVICE_SECRET_KEY=tournament-service-secret-key-change-in-production
TOURNAMENT_SERVICE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tournament_db
TOURNAMENT_SERVICE_REDIS_URL=redis://redis:6379/2

# Submission Service Configuration
SUBMISSION_SERVICE_DEBUG=True
SUBMISSION_SERVICE_SECRET_KEY=submission-service-secret-key-change-in-production
SUBMISSION_SERVICE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/submission_db
SUBMISSION_SERVICE_REDIS_URL=redis://redis:6379/3

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Tournament Platform

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=innovators_db

# Redis Configuration
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
